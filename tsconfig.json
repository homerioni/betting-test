{
  "include": ["src"],
  "exclude": ["src/**/cypress"],
  "compilerOptions": {
    "target": "es2020",
    "lib": [
      "es2020",
      "dom"
    ],
    "jsx": "react-jsx",
    "module": "es2020",
    "moduleResolution": "node",
    "baseUrl": "./src",
    "ignoreDeprecations": "6.0",
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  }
}
